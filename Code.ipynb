        "# 2.5 Create a visualization showing connection attempts over time.\n",
        "\n",
        "from matplotlib.dates import DateFormatter\n",
        "\n",
        "# Set style for better visuals\n",
        "sns.set(style=\"whitegrid\")\n",
        "plt.figure(figsize=(14, 8))\n",
        "\n",
        "# Convert timestamp to proper datetime format\n",
        "df2['datetime'] = pd.to_datetime(df2['ts'], unit='s')\n",
        "\n",
        "# Resample to minute or hour frequency\n",
        "time_series = df2.set_index('datetime').resample('5T').size()  # 5-minute intervals\n",
        "\n",
        "plt.subplot(2, 1, 2)\n",
        "time_series.plot(color='royalblue', title='Total Connection Attempts (5-min intervals)')\n",
        "plt.ylabel('Connection Count')\n",
        "plt.xlabel('Time')\n",
        "\n",
        "# Other plot: Successful vs Failed Connections\n",
        "# Separate Successful vs Failed Connections\n",
        "df2['status'] = df2['conn_state'].apply(lambda x: 'Success' if x in ['SF', 'SHR'] else 'Failed')\n",
        "\n",
        "status_series = df2.set_index('datetime').groupby([pd.Grouper(freq='5T'), 'status']).size().unstack()\n",
        "\n",
        "plt.subplot(2, 1, 2)\n",
        "status_series.plot(kind='area', stacked=True,\n",
        "                  title='Successful vs Failed Connections (5-min intervals)')\n",
        "plt.ylabel('Connection Count')\n",
        "plt.xlabel('Time')\n",
        "\n",
        "plt.show()\n",
        "\n"
