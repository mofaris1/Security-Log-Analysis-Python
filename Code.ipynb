      "source": [
        "# 2.2 Analyze the distribution of allowed vs. blocked connections.\n",
        "\n",
        "# Connection distribution:\n",
        "connection_distribution = df2['conn_state'].value_counts()\n",
        "print(connection_distribution)\n",
        "\n",
        "# Group connection states into Allowed and Blocked:\n",
        "allowed_states = ['SF', 'SHR']  # Allowed Connections\n",
        "blocked_states = ['REJ', 'S0', 'RSTR', 'RSTO', 'OTH', 'SH', 'S1']  # Blocked Connections\n",
        "\n",
        "# Calculate counts\n",
        "allowed_count = df2[df2['conn_state'].isin(allowed_states)]['conn_state'].count()\n",
        "blocked_count = df2[df2['conn_state'].isin(blocked_states)]['conn_state'].count()\n",
        "\n",
        "# Create summary\n",
        "connection_summary = pd.DataFrame({\n",
        "    'Status': ['Allowed', 'Blocked'],\n",
        "    'Count': [allowed_count, blocked_count],\n",
        "    'Percentage': [\n",
        "        (allowed_count/len(df2))*100,\n",
        "        (blocked_count/len(df2))*100\n",
        "    ]\n",
        "})\n",
        "\n",
        "print('\\n', connection_summary)\n",
        "\n",
        "# Create pie chart\n",
        "plt.figure(figsize=(8, 8))\n",
        "colors = ['#00ff00', '#FF0000']\n",
        "explode = (0, 0.1)\n",
        "\n",
        "plt.pie(\n",
        "    connection_summary['Percentage'],\n",
        "    labels=connection_summary['Status'],\n",
        "    autopct='%1.1f%%',\n",
        "    startangle=90,\n",
        "    colors=colors,\n",
        "    explode=explode,\n",
        "    textprops={'fontsize': 12, 'fontweight': 'bold'}\n",
        ")\n",
        "\n",
        "plt.title('Allowed vs. Blocked Connections', pad=20, size=14, weight=\"bold\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
