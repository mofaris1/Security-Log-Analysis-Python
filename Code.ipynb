    {
      "cell_type": "code",
      "source": [
        "# 3.3 Find the top usernames targeted in failed login attempts.\n",
        "\n",
        "failed_logins = df[df['status'] == 'failed']\n",
        "top_targeted_users = failed_logins['username'].value_counts().head(10)\n",
        "\n",
        "# Create a plot\n",
        "plt.figure(figsize=(12, 6))\n",
        "barplot = sns.barplot(\n",
        "    x=top_targeted_users.index,\n",
        "    y=top_targeted_users.values,\n",
        "    palette='Reds_r'\n",
        ")\n",
        "\n",
        "# Customize the plot\n",
        "plt.title('Top 10 Targeted Usernames in Failed SSH Logins', pad=20, size=14, weight='bold')\n",
        "plt.xlabel('Username', labelpad=10, weight='bold')\n",
        "plt.ylabel('Number of Failed Attempts', labelpad=10, weight='bold')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "\n",
        "# Add value labels on top of bars\n",
        "for index, value in enumerate(top_targeted_users.values):\n",
        "    plt.text(\n",
        "        index,\n",
        "        value + 0.5,  # Position text slightly above bar\n",
        "        str(value),\n",
        "        ha='center',\n",
        "        va='bottom',\n",
        "        fontweight='bold'\n",
        "    )\n",
        "\n",
        "plt.show()"
      ],
