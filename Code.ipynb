      "cell_type": "code",
      "source": [
        "# Give every column name that descripe that column\n",
        "\n",
        "# 1. ts: Timestamp when the connection started (UNIX time)\n",
        "# 2. uid:\tUnique ID for the connection, 3. id.orig_h:\tOriginating host IP address\n",
        "# 4. id.orig_p:\tOriginating port, 5. id.resp_h:\tResponding host IP address\n",
        "# 6. id.resp_p:\tResponding port, 7.\tproto:\tProtocol (usually tcp, udp, or icmp), 8. service: Detected application protocol (e.g., http, dns, ssl)\n",
        "# 9. duration: Connection duration (seconds)\n",
        "# 10. orig_bytes:\tBytes sent from originator, 11.\tresp_bytes:\tBytes sent from responder, 12. conn_state:\tConnection state (e.g., SF, REJ, S0)\n",
        "# 13. local_orig:\tIf originator is local (optional, may be -), 14. missed_bytes:\tNumber of bytes missed due to packet loss\n",
        "# 15.\thistory:\tConnection history flags, 16. orig_pkts:\tPackets sent by originator, 17. orig_ip_bytes:\tIP bytes sent by originator\n",
        "# 18. resp_pkts:\tPackets sent by responder, 19. resp_ip_bytes: IP bytes sent by responder\n",
        "# 20. tunnel_parents:\tParent tunnel UIDs if encapsulated (or empty)\n",
        "\n",
        "columns = ['ts', 'uid', 'id.orig_h', 'id.orig_p', 'id.resp_h', 'id.resp_p', 'proto', 'service', 'duration', 'orig_bytes', 'resp_bytes',\\\n",
        "           'conn_state', 'local_orig', 'missed_bytes', 'history', 'orig_pkts', 'orig_ip_bytes', 'resp_pkts', 'resp_ip_bytes', 'tunnel_parents']\n",
        "\n",
        "df2.columns = columns\n",
        "\n",
        "df2"
      ],
