    {
      "cell_type": "code",
      "source": [
        "# 3.4 Identify potential brute force attacks by finding multiple failed attempts from the same IP.\n",
        "\n",
        "# Group by IP and count failed attempts\n",
        "brute_force_suspects = failed_logins.groupby('ip').agg(\n",
        "    attempts=('ip', 'count'),\n",
        "    first_attempt=('datetime', 'min'),\n",
        "    last_attempt=('datetime', 'max'),\n",
        "    usernames_tried=('username', lambda x: x.nunique())\n",
        ").sort_values('attempts', ascending=False)\n",
        "\n",
        "# Filter for IPs with multiple attempts\n",
        "brute_force_suspects = brute_force_suspects[brute_force_suspects['attempts'] > 200]\n",
        "print(\"\\nPotential Brute Force Attacks (IPs with >200 failed attempts):\")\n",
        "print(brute_force_suspects)\n",
        "\n",
        "\n",
        "\n",
        "# More:\n",
        "# Get top 10 IPs by attempts\n",
        "top_attackers = brute_force_suspects.sort_values('attempts', ascending=False).head(10)\n",
        "\n",
        "# Plot\n",
        "plt.figure(figsize=(12, 6))\n",
        "sns.barplot(\n",
        "    x=top_attackers.index,\n",
        "    y=top_attackers['attempts'],\n",
        "    palette='rocket_r'\n",
        ")\n",
        "\n",
        "# Customize\n",
        "plt.title('Top 10 Brute-Force Attackers (by Attempts)', fontweight='bold', pad=20)\n",
        "plt.xlabel('Attacker IP', fontweight='bold')\n",
        "plt.ylabel('Failed Attempts', fontweight='bold')\n",
        "plt.xticks(rotation=45, ha='right')\n",
        "\n",
        "# Add attempt counts on bars\n",
        "for i, count in enumerate(top_attackers['attempts']):\n",
        "    plt.text(i, count + 2, str(count), ha='center', fontweight='bold')\n",
        "\n",
        "plt.show()"
      ],
