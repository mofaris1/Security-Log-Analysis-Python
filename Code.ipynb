        "**Task4: Cross-Dataset Correlation:**\n",
        "\n",
        "Perform a correlation analysis between at least two of the datasets:\n"
      ],
      "metadata": {
        "id": "aUzUzt1yBXp_"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# 4.1 Identify common IP addresses appearing in multiple datasets.\n",
        "\n",
        "# IPs from SSH dataset\n",
        "ssh_ips = set(df['ip'].dropna())\n",
        "\n",
        "# IPs from Apache dataset\n",
        "apache_ips = set(extracted_df['client'].dropna())\n",
        "\n",
        "# Find common IPs\n",
        "common_ips = ssh_ips.intersection(apache_ips)\n",
        "\n",
        "print(f\"Found {len(common_ips)} common IP addresses:\")\n",
        "print(common_ips)"
      ],
