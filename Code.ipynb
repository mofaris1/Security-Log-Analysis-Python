      "source": [
        "# 3.2 Identify the distribution of successful vs. failed login attempts.\n",
        "\n",
        "status_distribution = df['status'].value_counts()\n",
        "print(\"Login Attempt Status Distribution:\")\n",
        "print(status_distribution)\n",
        "\n",
        "\n",
        "# Pie Chart:\n",
        "# Filter 'success' and 'failed' statuses\n",
        "status_distribution = df[df['status'].isin(['success', 'failed'])]['status'].value_counts()\n",
        "\n",
        "# Create pie chart\n",
        "plt.figure(figsize=(8, 8))\n",
        "colors = ['#FF0000', '#00ff00']\n",
        "explode = (0, 0.1)\n",
        "\n",
        "plt.pie(\n",
        "    status_distribution,\n",
        "    labels=status_distribution.index,\n",
        "    autopct='%1.1f%%',\n",
        "    startangle=90,\n",
        "    colors=colors,\n",
        "    explode=explode,\n",
        "    textprops={'fontsize': 12, 'fontweight': 'bold'}\n",
        ")\n",
        "\n",
        "plt.title('SSH Login Attempts\\n(Success vs Failed)', pad=20, size=14, weight=\"bold\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "metadata": {
