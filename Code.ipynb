      "source": [
        "# 4.2 Create a timeline of events for these common IPs across datasets.\n",
        "\n",
        "# Create SSH events dataframe for common IPs\n",
        "ssh_events = df[df['ip'].isin(common_ips)][['datetime', 'ip', 'status', 'username', 'message']]\n",
        "ssh_events['source'] = 'SSH'\n",
        "\n",
        "# Create Apache events dataframe for common IPs\n",
        "apache_events = extracted_df[extracted_df['client'].isin(common_ips)].copy()\n",
        "apache_events = apache_events.rename(columns={'client': 'ip', 'Message': 'message'})\n",
        "apache_events['datetime'] = apache_logs_df['Timestamp']  # Assuming aligned indices\n",
        "apache_events['status'] = 'web_request'\n",
        "apache_events['username'] = None\n",
        "apache_events['source'] = 'Apache'\n",
        "\n",
        "# Combine both datasets\n",
        "combined_events = pd.concat([ssh_events, apache_events]).sort_values('datetime')\n",
        "\n",
        "# Display timeline\n",
        "print(\"\\nTimeline of events for common IPs:\")\n",
        "display(combined_events)\n",
        "\n",
        "# Visualize activity patterns\n",
        "plt.figure(figsize=(14, 6))\n",
        "for ip in common_ips:\n",
        "    ip_events = combined_events[combined_events['ip'] == ip]\n",
        "    plt.scatter(ip_events['datetime'], [ip]*len(ip_events),\n",
        "               label=ip, alpha=0.7)\n",
        "\n",
        "plt.title('Activity Timeline of Common IPs Across Both Logs')\n",
        "plt.xlabel('Timestamp')\n",
        "plt.ylabel('IP Address')\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "plt.tight_layout()\n",
        "plt.show()"
