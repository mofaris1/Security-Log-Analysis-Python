        "# 2.4 Find patterns in connection attempts to sensitive ports.\n",
        "\n",
        "sensitive_ports = {\n",
        "    22: 'SSH',\n",
        "    23: 'Telnet',\n",
        "    3389: 'RDP',\n",
        "    445: 'SMB',\n",
        "    1433: 'MSSQL',\n",
        "    3306: 'MySQL',\n",
        "    5432: 'PostgreSQL',\n",
        "    5900: 'VNC',\n",
        "    8080: 'HTTP-Alt',\n",
        "    21: 'FTP'\n",
        "}\n",
        "\n",
        "# Convert port column to numeric\n",
        "df2['id.resp_p'] = pd.to_numeric(df2['id.resp_p'])\n",
        "\n",
        "# Convert timestamp to datetime\n",
        "df2['timestamp'] = pd.to_datetime(df2['ts'], unit='s')\n",
        "\n",
        "# Filter for sensitive ports\n",
        "sensitive_conns = df2[df2['id.resp_p'].isin(sensitive_ports.keys())]\n",
        "\n",
        "\n",
        "\n",
        "# Analysis of Sensitive Port\n",
        "port_activity = sensitive_conns['id.resp_p'].value_counts()\n",
        "port_activity = port_activity.rename(index=sensitive_ports)\n",
        "print(\"Connection attempts by sensitive port:\")\n",
        "print(port_activity)\n",
        "\n",
        "# Success Rate by Sensitive Port\n",
        "port_success = sensitive_conns.groupby('id.resp_p')['conn_state'].apply(\n",
        "    lambda x: x.isin(['SF', 'SHR']).sum()/len(x)*100\n",
        ")\n",
        "port_success = port_success.rename(index=sensitive_ports)\n",
        "print(\"\\nSuccess rate by sensitive port (%):\")\n",
        "print(port_success.sort_values(ascending=False))\n",
        "\n",
        "# Top Source IPs Targeting Sensitive Ports\n",
        "top_attackers = sensitive_conns['id.orig_h'].value_counts().head(10)\n",
        "print(\"\\nTop source IPs targeting sensitive ports:\")\n",
        "print(top_attackers)\n",
        "\n",
        "\n",
        "# Plot hourly attempts to sensitive ports\n",
        "sensitive_conns['hour'] = sensitive_conns['timestamp'].dt.hour\n",
        "hourly_attempts = sensitive_conns['hour'].value_counts().sort_index()\n",
        "\n",
        "plt.figure(figsize=(12, 6))\n",
        "hourly_attempts.plot(kind='bar', title='Hourly Attempts on Sensitive Ports')\n",
        "plt.xlabel('Hour of Day')\n",
        "plt.ylabel('Attempt Count')\n",
        "plt.show()"
