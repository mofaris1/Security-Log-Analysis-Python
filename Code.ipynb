      "source": [
        "# 1.1 Parse the Apache logs into a pandas DataFrame with appropriate columns.\n",
        "\n",
        "file = open('Apache.log', 'r')\n",
        "apache_log_data =[]\n",
        "for line in file:\n",
        "  apache_log_data.append(line.strip())\n",
        "file.close()\n",
        "\n",
        "log_pattern = re.compile(r'\\[(.*?)\\] \\[(.*?)\\] (.*)')\n",
        "\n",
        "extracted_data = []\n",
        "for line in apache_log_data:\n",
        "    match = log_pattern.match(line)\n",
        "    if match:\n",
        "        extracted_data.append(match.groups())\n",
        "\n",
        "apache_logs_df = pd.DataFrame(extracted_data, columns=['Timestamp', 'Log Level', 'Message'])\n",
        "\n",
        "apache_logs_df['Timestamp'] = pd.to_datetime(apache_logs_df['Timestamp'], errors='coerce')\n",
        "display(apache_logs_df.head())"
      ],
