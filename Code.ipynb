      "cell_type": "code",
      "source": [
        "df2.drop(['local_orig', 'service'], axis=1, inplace=True)\n",
        "\n",
        "# Get the most frequant word to fill it\n",
        "mode = df2['history'].mode().iloc[0]\n",
        "print('The most frequant in DataFram is : ', mode)\n",
        "\n",
        "# Cleaning\n",
        "df2['history'].fillna(mode, inplace=True)\n",
        "\n",
        "# Cleaning\n",
        "df2['resp_bytes'] = pd.to_numeric(df2['resp_bytes'], errors='coerce')\n",
        "resp_bytes_mean = df2['resp_bytes'].dropna().mean()\n",
        "df2['resp_bytes'].fillna(resp_bytes_mean, inplace=True)\n",
        "\n",
        "# Cleaning\n",
        "df2['duration'] = pd.to_numeric(df2['duration'], errors='coerce')\n",
        "duration_mean = df2['duration'].dropna().mean()\n",
        "df2['duration'].fillna(duration_mean, inplace=True)\n",
