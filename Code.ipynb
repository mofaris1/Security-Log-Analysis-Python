    {
      "cell_type": "code",
      "source": [
        "# 3.1 Parse the authentication logs into a pandas DataFrame with appropriate columns.\n",
        "\n",
        "# Read the log file\n",
        "with open('auth.log', 'r') as f:\n",
        "    log_data = f.read()\n",
        "\n",
        "# Parse each log entry\n",
        "entries = []\n",
        "for line in log_data.split('\\n'):\n",
        "    if not line.strip():\n",
        "        continue\n",
        "\n",
        "    # Extract timestamp, host, process, and message\n",
        "    match = re.match(r'^(\\w{3}\\s+\\d{1,2} \\d{2}:\\d{2}:\\d{2}) (\\S+) (\\S+): (.*)$', line)\n",
        "    if match:\n",
        "        timestamp, host, process, message = match.groups()\n",
        "\n",
        "        # Parse IP addresses and usernames from messages\n",
        "        ip = None\n",
        "        username = None\n",
        "        status = 'other'\n",
        "\n",
        "        # Check for failed login attempts\n",
        "        if 'Invalid user' in message:\n",
        "            status = 'failed'\n",
        "            user_match = re.search(r'Invalid user (\\S+) from (\\S+)', message)\n",
        "            if user_match:\n",
        "                username, ip = user_match.groups()\n",
        "\n",
        "        # Check for connection closed without auth\n",
        "        elif 'Connection closed by' in message and 'preauth' in message:\n",
        "            status = 'failed'\n",
        "            ip_match = re.search(r'Connection closed by (\\S+)', message)\n",
        "            if ip_match:\n",
        "                ip = ip_match.group(1)\n",
        "\n",
        "        # Check for did not receive identification string\n",
        "        elif 'Did not receive identification string from' in message:\n",
        "            status = 'failed'\n",
        "            ip_match = re.search(r'Did not receive identification string from (\\S+)', message)\n",
        "            if ip_match:\n",
        "                ip = ip_match.group(1)\n",
        "\n",
        "        # Check for successful\n",
        "        elif 'pam_unix(cron:session): session opened for user' in message:\n",
        "            status = 'success'\n",
        "            user_match = re.search(r'session opened for user (\\S+)', message)\n",
        "            if user_match:\n",
        "                username = user_match.group(1)\n",
        "\n",
        "        entries.append({\n",
        "            'timestamp': timestamp,\n",
        "            'host': host,\n",
        "            'process': process,\n",
        "            'message': message,\n",
        "            'status': status,\n",
        "            'ip': ip,\n",
        "            'username': username\n",
        "        })\n",
        "\n",
        "# Create DataFrame\n",
        "df = pd.DataFrame(entries)\n",
        "\n",
        "# Convert timestamp to datetime (assuming current year)\n",
        "df['datetime'] = pd.to_datetime(df['timestamp'] + f' {2005}', format='%b %d %H:%M:%S %Y')\n",
        "\n",
        "display(df)"
      ],
